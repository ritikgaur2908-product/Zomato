# Dataset
DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation
DATASET_CACHE_PATH=data/cache/restaurants.parquet

# Budget tier thresholds (cost for two, INR)
BUDGET_LOW_MAX=500
BUDGET_MEDIUM_MAX=1500

# Filtering
CANDIDATE_LIMIT=20
MAX_TOP_N=20
EXTRAS_MATCH_MODE=and
INCLUDE_UNKNOWN_BUDGET=false

# LLM (Phase 3+) — Groq: https://console.groq.com/
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=2048
